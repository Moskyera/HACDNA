# Data provider: mainnet | mock | explorer | node
HACD_DATA_PROVIDER=mainnet
NEXT_PUBLIC_HACD_DATA_PROVIDER=mainnet

# Hacash mainnet fullnode RPC (public default works without local node)
# On Vercel set this in Project → Settings → Environment Variables
HACASH_NODE_RPC_URL=http://nodeapi.hacash.org

# Optional alternate explorer HTTP base (future mapping)
HACD_EXPLORER_API_URL=

# PostgreSQL (optional Prisma indexing)
DATABASE_URL=postgresql://user:password@localhost:5432/hacd_rarity?schema=public
